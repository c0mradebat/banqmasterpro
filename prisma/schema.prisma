// BanqMaster Pro — Banquet Hall Management System
// Postgres + Prisma

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── AUTH & STAFF ────────────────────────────────────────────────────────────

/**
 * Roles are first-class data. The 7 keys below are seeded as `isSystem = true`
 * and cannot be deleted/renamed; admins can edit their permissions and add new
 * non-system roles freely.
 */
enum Role {
  OWNER
  ADMIN
  MANAGER
  RECEPTIONIST
  ACCOUNTANT
  STAFF
  DEV
}

model RoleDef {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String?
  /** Numeric authority hint, used only for sorting / hierarchy display. Permissions are the actual gate. */
  level       Int      @default(0)
  /** True for the 7 seeded defaults; locks key/name from edits and prevents deletion. */
  isSystem    Boolean  @default(false)
  /** Permission keys this role grants. See src/lib/permissions.ts for the catalog. */
  permissions String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  username      String    @unique
  passwordHash  String
  role          Role      @default(STAFF) // legacy enum, mirrored by roleId for transition
  roleId        String?
  roleDef       RoleDef?  @relation(fields: [roleId], references: [id], onDelete: SetNull)
  phone         String?
  avatarUrl     String?
  pin           String?   // for kiosk-style action authorization
  active        Boolean   @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  bookingsCreated   Booking[]   @relation("BookingCreator")
  enquiriesCreated  Enquiry[]   @relation("EnquiryCreator")
  paymentsRecorded  Payment[]   @relation("PaymentRecorder")
  auditLogs         AuditLog[]
  meterReadings     MeterReading[]
  notifications     Notification[]
  todos             Todo[]

  @@index([roleId])
}

// ─── CUSTOMERS ───────────────────────────────────────────────────────────────

model Customer {
  id        String   @id @default(cuid())
  firstName String
  lastName  String?
  phone     String   @unique
  altPhone  String?
  email     String?
  city      String?
  state     String?
  address   String?
  notes     String?
  blacklist Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  enquiries Enquiry[]
  bookings  Booking[]
}

// ─── VENUE / ROOMS ───────────────────────────────────────────────────────────

enum RoomType {
  NON_BALCONY
  BALCONY
  DORMITORY
  SUITE
}

enum RoomStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
  DIRTY
  RESERVED
}

model Room {
  id         String      @id @default(cuid())
  number     String      @unique
  type       RoomType
  floor      Int         @default(0)
  capacity   Int         @default(2)
  status     RoomStatus  @default(AVAILABLE)
  notes      String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  allocations RoomAllocation[]
}

// ─── ENQUIRIES ───────────────────────────────────────────────────────────────

enum EnquiryStatus {
  NEW
  CONTACTED
  QUOTED
  CONVERTED
  LOST
  CANCELLED
}

enum EventType {
  MARRIAGE
  RECEPTION
  ENGAGEMENT
  BIRTHDAY
  ANNIVERSARY
  CORPORATE
  CONFERENCE
  POOL_PARTY
  ROOMS_ONLY
  OTHER
}

model Enquiry {
  id           String        @id @default(cuid())
  code         String        @unique
  status       EnquiryStatus @default(NEW)
  eventType    EventType     @default(OTHER)
  eventStart   DateTime?
  eventEnd     DateTime?
  guestCount   Int?
  notes        String?

  // Services interest
  hasMarriageHall  Boolean @default(false)
  hasDiningHall    Boolean @default(false)
  hasShahiBhoj     Boolean @default(false)
  hasLawn          Boolean @default(false)
  hasSwimmingPool  Boolean @default(false)
  hasPoolRefill    Boolean @default(false)
  hasPoolParty     Boolean @default(false)
  hasDjHall        Boolean @default(false)
  hasCocktail      Boolean @default(false)
  hasRooms         Boolean @default(false)

  customerId   String
  customer     Customer @relation(fields: [customerId], references: [id])

  createdById  String
  createdBy    User     @relation("EnquiryCreator", fields: [createdById], references: [id])

  convertedBookingId String?  @unique
  convertedBooking   Booking? @relation("EnquiryConversion", fields: [convertedBookingId], references: [id])

  quotations Quotation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([eventStart])
}

// ─── BOOKINGS ────────────────────────────────────────────────────────────────

enum BookingStatus {
  TENTATIVE
  CONFIRMED
  CHECKED_IN
  COMPLETED
  CANCELLED
  REFUNDED
}

model Booking {
  id                String         @id @default(cuid())
  code              String         @unique     // BM-2026-0001
  status            BookingStatus  @default(TENTATIVE)
  eventType         EventType      @default(OTHER)
  bookingDate       DateTime       @default(now())
  eventStart        DateTime
  eventEnd          DateTime
  guestCount        Int?

  // Customer
  customerId        String
  customer          Customer @relation(fields: [customerId], references: [id])

  // Services flags (for quick filtering)
  hasMarriageHall   Boolean @default(false)
  hasDiningHall     Boolean @default(false)
  hasShahiBhoj      Boolean @default(false)
  hasLawn           Boolean @default(false)
  hasSwimmingPool   Boolean @default(false)
  hasPoolRefill     Boolean @default(false)
  hasPoolParty      Boolean @default(false)
  hasDjHall         Boolean @default(false)
  hasCocktail       Boolean @default(false)

  // Vendor services
  cateringVendorId  String?
  cateringVendor    Vendor?  @relation("BookingCatering", fields: [cateringVendorId], references: [id])
  decorationVendorId String?
  decorationVendor  Vendor?  @relation("BookingDecoration", fields: [decorationVendorId], references: [id])
  eventMgmtVendorId String?
  eventMgmtVendor   Vendor?  @relation("BookingEventMgmt", fields: [eventMgmtVendorId], references: [id])

  // Pricing
  subtotal          Decimal  @default(0) @db.Decimal(12,2)
  discount          Decimal  @default(0) @db.Decimal(12,2)
  discountReason    String?
  miscCharges       Decimal  @default(0) @db.Decimal(12,2)
  miscReason        String?
  electricityUnits  Decimal  @default(0) @db.Decimal(12,2)
  electricityRate   Decimal  @default(0) @db.Decimal(12,2) // per unit
  electricityCharge Decimal  @default(0) @db.Decimal(12,2)
  generatorHours    Decimal  @default(0) @db.Decimal(12,2)
  generatorRate     Decimal  @default(0) @db.Decimal(12,2) // per hour
  generatorCharge   Decimal  @default(0) @db.Decimal(12,2)
  addonMattresses   Int      @default(0)
  addonMattressRate Decimal  @default(0) @db.Decimal(12,2)
  securityDeposit   Decimal  @default(0) @db.Decimal(12,2)
  totalAmount       Decimal  @default(0) @db.Decimal(12,2) // subtotal - discount + extras
  paidAmount        Decimal  @default(0) @db.Decimal(12,2) // sum of payments
  refundAmount      Decimal  @default(0) @db.Decimal(12,2) // refunded after final calc
  balanceDue        Decimal  @default(0) @db.Decimal(12,2)

  // GST (internal use only — never charge customer)
  gstNumber         String?
  gstPercent        Decimal  @default(18) @db.Decimal(5,2)

  notes             String?
  internalNotes     String?

  createdById       String
  createdBy         User     @relation("BookingCreator", fields: [createdById], references: [id])

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  cancelledAt       DateTime?
  cancelReason      String?
  /** Soft-delete marker. Bookings are never hard-deleted by the app — they are tombstoned
      so all financial history remains queryable. */
  deletedAt         DateTime?

  serviceItems      BookingServiceItem[]
  payments          Payment[]
  roomAllocations   RoomAllocation[]
  meterReadings     MeterReading[]
  enquiry           Enquiry? @relation("EnquiryConversion")

  @@index([eventStart])
  @@index([status])
  @@index([deletedAt])
}

enum ServiceKind {
  MARRIAGE_HALL
  DINING_HALL
  SHAHI_BHOJ
  LAWN
  SWIMMING_POOL
  POOL_REFILL
  POOL_PARTY
  DJ_HALL
  COCKTAIL_PARTY
  ROOM_NON_BALCONY
  ROOM_BALCONY
  ROOM_DORMITORY
  ROOM_SUITE
  COMPLIMENTARY_ROOM
}

model BookingServiceItem {
  id          String      @id @default(cuid())
  bookingId   String
  booking     Booking     @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  kind        ServiceKind
  label       String?
  startsAt    DateTime?
  endsAt      DateTime?
  quantity    Int         @default(1)
  unitPrice   Decimal     @default(0) @db.Decimal(12,2)
  total       Decimal     @default(0) @db.Decimal(12,2)
  notes       String?

  @@index([bookingId])
  @@index([kind])
}

model RoomAllocation {
  id        String   @id @default(cuid())
  bookingId String
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  roomId    String
  room      Room     @relation(fields: [roomId], references: [id])
  startsAt  DateTime
  endsAt    DateTime
  isComplimentary Boolean @default(false)
  guestName String?
  notes     String?

  @@index([roomId])
  @@index([startsAt, endsAt])
}

// ─── PAYMENTS ────────────────────────────────────────────────────────────────

enum PaymentMethod {
  CASH
  UPI
  CARD
  BANK_TRANSFER
  CHEQUE
  OTHER
}

enum PaymentKind {
  ADVANCE
  PARTIAL
  FINAL
  SECURITY_DEPOSIT
  REFUND
  ADJUSTMENT
}

model Payment {
  id            String         @id @default(cuid())
  bookingId     String
  booking       Booking        @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  amount        Decimal        @db.Decimal(12,2)
  kind          PaymentKind    @default(PARTIAL)
  method        PaymentMethod  @default(CASH)
  reference     String?        // txn id / cheque no
  receivedAt    DateTime       @default(now())
  notes         String?

  recordedById  String
  recordedBy    User     @relation("PaymentRecorder", fields: [recordedById], references: [id])

  createdAt     DateTime @default(now())
  /** Soft-delete marker. Payments are tombstoned, never hard-deleted, so audits stay traceable. */
  deletedAt     DateTime?

  @@index([bookingId])
  @@index([deletedAt])
}

// ─── ELECTRICITY METER READINGS ──────────────────────────────────────────────

model MeterReading {
  id        String   @id @default(cuid())
  bookingId String?
  booking   Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  reading   Decimal  @db.Decimal(12,2)
  readingAt DateTime @default(now())
  kind      String   @default("MAIN") // MAIN, GENERATOR, etc.
  photoUrl  String?
  notes     String?
  recordedById String?
  recordedBy User?    @relation(fields: [recordedById], references: [id])
  createdAt DateTime @default(now())

  @@index([bookingId])
  @@index([readingAt])
}

// ─── VENDORS ─────────────────────────────────────────────────────────────────

enum VendorKind {
  CATERER
  DECORATOR
  EVENT_MANAGER
  DJ
  PHOTOGRAPHER
  FLORIST
  OTHER
}

model Vendor {
  id        String     @id @default(cuid())
  name      String
  kind      VendorKind
  phone     String?
  email     String?
  address   String?
  notes     String?
  rating    Int?       @default(0)
  active    Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  bookingsCatering   Booking[] @relation("BookingCatering")
  bookingsDecoration Booking[] @relation("BookingDecoration")
  bookingsEventMgmt  Booking[] @relation("BookingEventMgmt")
}

// ─── INVENTORY ───────────────────────────────────────────────────────────────

model InventoryItem {
  id          String   @id @default(cuid())
  name        String
  sku         String?  @unique
  category    String?  // mattress, towel, chair, etc.
  unitCost    Decimal  @default(0) @db.Decimal(12,2)
  currentStock Int     @default(0)
  minStock    Int      @default(0)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── SETTINGS ────────────────────────────────────────────────────────────────

// Singleton row holding default prices/rates
model Settings {
  id                       String   @id @default("default")
  venueName                String   @default("Silver Star Banquets")
  venueAddress             String?
  venuePhone               String?
  venueEmail               String?
  gstNumber                String?
  currency                 String   @default("INR")

  // Default service rates
  marriageHallRate         Decimal  @default(50000) @db.Decimal(12,2)
  diningHallRate           Decimal  @default(20000) @db.Decimal(12,2)
  shahiBhojRate            Decimal  @default(15000) @db.Decimal(12,2)
  lawnRate                 Decimal  @default(25000) @db.Decimal(12,2)
  swimmingPoolRate         Decimal  @default(10000) @db.Decimal(12,2)
  poolRefillRate           Decimal  @default(3000)  @db.Decimal(12,2)
  poolPartyFee             Decimal  @default(8000)  @db.Decimal(12,2)
  djHallRate               Decimal  @default(15000) @db.Decimal(12,2)
  cocktailRate             Decimal  @default(20000) @db.Decimal(12,2)

  nonBalconyRoomRate       Decimal  @default(2000)  @db.Decimal(12,2)
  balconyRoomRate          Decimal  @default(2500)  @db.Decimal(12,2)
  dormitoryRoomRate        Decimal  @default(1500)  @db.Decimal(12,2)
  suiteRoomRate            Decimal  @default(4500)  @db.Decimal(12,2)
  addonMattressRate        Decimal  @default(300)   @db.Decimal(12,2)

  electricityRatePerUnit   Decimal  @default(12)    @db.Decimal(12,2)
  generatorRatePerHour     Decimal  @default(800)   @db.Decimal(12,2)

  defaultGstPercent        Decimal  @default(18)    @db.Decimal(5,2)
  freeRoomsPerBooking      Int      @default(0)

  updatedAt                DateTime @updatedAt
}

model BlackoutDate {
  id        String   @id @default(cuid())
  date      DateTime @db.Date
  reason    String?
  createdAt DateTime @default(now())

  @@unique([date])
}

// ─── AUDIT / ACTIVITY / NOTIFICATIONS / TODOS ────────────────────────────────

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  action      String   // CREATE_BOOKING, UPDATE_PAYMENT, ...
  entity      String   // Booking, Payment, ...
  entityId    String?
  description String?
  meta        Json?
  ip          String?
  createdAt   DateTime @default(now())

  @@index([entity, entityId])
  @@index([createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  body      String?
  href      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
}

enum TodoPriority {
  LOW
  MEDIUM
  HIGH
}

model Todo {
  id        String       @id @default(cuid())
  title     String
  done      Boolean      @default(false)
  priority  TodoPriority @default(MEDIUM)
  dueDate   DateTime?
  userId    String
  user      User         @relation(fields: [userId], references: [id])
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model Quotation {
  id          String   @id @default(cuid())
  code        String   @unique
  customerId  String?
  customerName String?
  phone       String?
  validUntil  DateTime?
  notes       String?
  total       Decimal  @default(0) @db.Decimal(12,2)
  body        Json     // line items

  enquiryId   String?
  enquiry     Enquiry? @relation(fields: [enquiryId], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([enquiryId])
}
