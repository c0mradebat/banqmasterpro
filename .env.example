# Database
DATABASE_URL="postgresql://banqmaster:banqmaster@localhost:5432/banqmaster?schema=public"

# NextAuth
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# App
APP_NAME="BanqMaster Pro"
DEFAULT_CURRENCY="INR"
DEFAULT_TIMEZONE="Asia/Kolkata"

# Optional: comma-separated usernames that bypass the login rate limit (dev only)
# AUTH_RATE_LIMIT_BYPASS="owner,admin"
